# ── Rust ─────────────────────────────────────────────────────────────────────
**/target/
**/*.rs.bk

# ── Node / Dashboard ─────────────────────────────────────────────────────────
**/node_modules/
**/dist/
**/.vite/

# ── Env files (never commit secrets) ─────────────────────────────────────────
**/.env
**/.env.*
**/env.yaml
# ...but commit example templates so teammates know what vars to set:
!**/.env.example
!**/.env.*.example
!**/env.example.yaml

# ── Logs & backups ───────────────────────────────────────────────────────────
**/*.log
**/*.bak
**/*.bak.*

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
frontend/

# ── Flux local state (per-project, never shared) ─────────────────────────────
# Generated type stubs, embedded postgres data, dev port, manifest cache.
# Recreated automatically by: flux dev, flux generate
.flux/

# ── Test / scratch functions (developer local only) ──────────────────────────
# Real project functions live in functions/ and are committed.
# test_functions/ is a local scratch pad — never deploy these.
test_functions/

# ── Docker (not used — flux dev uses embedded Postgres, no Docker needed) ────
Dockerfile
docker-compose*.yml
.dockerignore

projects/

# ── WASM build artifacts (generated; not checked in) ─────────────────────────
build/
rubies/
flux-functions/
nuitka-crash-report.xml

# ── Java/Gradle build outputs ─────────────────────────────────────────────────
examples/hello-java/functions/hello/.gradle/
examples/hello-java/functions/hello/build/
examples/hello-java/functions/hello/*.class
examples/hello-java/functions/hello/*.jar

# ── C# build outputs ──────────────────────────────────────────────────────────
examples/hello-csharp/functions/hello/bin/
examples/hello-csharp/functions/hello/obj/

# ── Large pre-compiled WASM runtimes (>10MB — too large for git) ──────────────
# Python: 26MB — build with: py2wasm handler.py -o hello.wasm
examples/hello-python/functions/hello/hello.wasm
# Ruby: 47MB — build with: rbwasm pack ruby.wasm --dir .:/ -o hello-ruby.wasm
examples/hello-ruby/functions/hello/*.wasm
