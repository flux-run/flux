{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/",                    "destination": "/home.html" },

    { "source": "/cli",                 "destination": "/cli.html" },
    { "source": "/product",             "destination": "/product.html" },
    { "source": "/how-it-works",        "destination": "/how-it-works.html" },

    { "source": "/docs",                "destination": "/docs/index.html" },
    { "source": "/docs/:page",          "destination": "/docs/:page.html" },

    { "source": "/examples",            "destination": "/examples/index.html" },
    { "source": "/examples/:page",      "destination": "/examples/:page.html" },

    { "source": "/blog/:page",          "destination": "/blog/:page.html" },

    { "source": "/login",               "destination": "/index.html" },
    { "source": "/dashboard",           "destination": "/index.html" },
    { "source": "/dashboard/:path*",    "destination": "/index.html" }
  ]
}

