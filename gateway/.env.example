# Flux Gateway — environment variable reference
# Copy to .env for local development:  cp .env.example .env
#
# All variables are read at startup.  Required ones cause a panic on missing.
# See docs/gateway.md for the full specification.

# ── Required ────────────────────────────────────────────────────────────────

# Postgres connection string.
DATABASE_URL=postgres://postgres:password@localhost:5432/flux

# Shared secret for service-to-service calls (gateway → runtime).
# Must match INTERNAL_SERVICE_TOKEN in the runtime service.
INTERNAL_SERVICE_TOKEN=dev-secret-change-in-production

# ── Optional (defaults shown) ────────────────────────────────────────────────

# Port this gateway listens on.
PORT=8081

# Runtime execution service URL.
RUNTIME_URL=http://localhost:8083

# API (control-plane) service URL.  Used for admin operations.
CONTROL_PLANE_URL=http://localhost:8080

# Hard limit on HTTP request body in bytes.  Requests above this return 413.
# Default: 10 MB.
MAX_REQUEST_SIZE_BYTES=10485760

# How often (seconds) to refresh the in-memory route snapshot from the DB.
SNAPSHOT_REFRESH_SECS=60

# HTTP timeout (seconds) for forwarded runtime calls.
RUNTIME_TIMEOUT_SECS=30

# Per-route default rate limit (requests / second per client IP).
RATE_LIMIT_PER_SEC=50

# Set to true when running with `flux dev` local stack.
# Skips authentication and injects a fixed dev identity.
LOCAL_MODE=false
