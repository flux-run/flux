# Fluxbase local development — secrets template
# Copy this file to .env.dev and fill in the values.
# .env.dev is gitignored; .env.dev.example is committed.
#
# Usage: flux stack up   (the CLI auto-loads .env.dev when present)

# ── Required ──────────────────────────────────────────────────────────────────

# Firebase project ID — used by the API for auth verification.
# Create a project at https://console.firebase.google.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Optional overrides ─────────────────────────────────────────────────────────

# Override the default postgres password (flux/flux).
# Also change the DATABASE_URL in docker-compose.dev.yml.
# POSTGRES_PASSWORD=your-secure-password

# S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
# Leave blank to skip file storage in local dev.
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=fluxbase-local
# S3_REGION=auto
