{
  "name": "flux-runtime-tests",
  "version": "0.1.0",
  "description": "Comprehensive runtime compatibility test suite for Flux",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "flux-runtime-test": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --loader tsx dist/cli.js",
    "test:watch": "tsc --watch",
    "test:ecmascript": "node --loader tsx dist/cli.js ecmascript",
    "test:node": "node --loader tsx dist/cli.js node",
    "test:web": "node --loader tsx dist/cli.js web",
    "test:frameworks": "node --loader tsx dist/cli.js frameworks",
    "test:runtime": "node --loader tsx dist/cli.js runtime",
    "test:determinism": "node --loader tsx dist/cli.js determinism",
    "test:errors": "node --loader tsx dist/cli.js error-handling",
    "test:concurrency": "node --loader tsx dist/cli.js concurrency",
    "test:trust": "node dist/src/cli.js trust",
    "test:compat": "node dist/src/cli.js compat",
    "test:replay": "node dist/src/cli.js replay",
    "test:modules": "node dist/src/cli.js modules",
    "test:all": "node --loader tsx dist/cli.js all",
    "test:262": "cd ../runners && npm run test:262",
    "test:node-compat": "cd ../runners && npm run test:node",
    "test:web-compat": "cd ../runners && npm run test:web",
    "test:npm": "cd ../runners && npm run test:npm",
    "test:report": "cd ../runners && npm run report",
    "test:compat-all": "cd ../runners && npm run test:all",
    "build:flux": "SQLX_OFFLINE=true cargo build -p cli -p runtime --manifest-path ../../Cargo.toml",
    "test:integration": "cd ../runners && npm run test:integration",
    "test:integration:skip-build": "cd ../runners && npm run test:integration:skip-build",
    "setup:external": "bash ../scripts/setup-external-tests.sh all",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "runtime",
    "testing",
    "compatibility",
    "v8",
    "typescript"
  ],
  "author": "Flux Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "axios": "^1.13.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zora": "^5.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "table": "^6.8.1"
  }
}
