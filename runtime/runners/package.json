{
  "name": "flux-compat-runners",
  "version": "0.1.0",
  "description": "Flux compatibility runners — Test262 · Node core · Web Platform Tests · NPM ecosystem (all run via flux run)",
  "type": "module",
  "scripts": {
    "test:262":   "tsx run-test262.ts",
    "test:node":  "tsx run-node-tests.ts",
    "test:web":   "tsx run-web-tests.ts",
    "test:npm":   "tsx run-npm-tests.ts",
    "report":     "tsx generate-report.ts",
    "build:flux": "SQLX_OFFLINE=true cargo build -p cli -p runtime --manifest-path ../../Cargo.toml",
    "test:integration": "tsx run-flux-integration.ts",
    "test:integration:skip-build": "tsx run-flux-integration.ts --skip-build",
    "test:all":   "npm run test:integration && npm run test:262 && npm run test:node && npm run test:web && npm run test:npm && npm run report",
    "setup":      "bash ../scripts/setup-external-tests.sh all"
  },
  "dependencies": {
    "axios":          "^1.6.8",
    "chalk":          "^5.3.0",
    "glob":           "^11.0.0",
    "jsonwebtoken":   "^9.0.2",
    "lodash":         "^4.17.21",
    "test262-harness":"^10.0.0",
    "uuid":           "^9.0.1",
    "zod":            "^3.22.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash":       "^4.17.0",
    "@types/node":         "^20.11.0",
    "tsx":                 "^4.7.0",
    "typescript":          "^5.3.3"
  }
}
