{
  "name": "@fluxbase/schema",
  "version": "0.1.0",
  "description": "Flux schema definition library — defineSchema, column, defineEnum, rules, hooks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev":   "tsup src/index.ts --format esm,cjs --dts --watch",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
