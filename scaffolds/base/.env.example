# Database — leave blank to use embedded Postgres (zero-config)
# Set this to connect to your own Postgres instance instead
# DATABASE_URL=postgres://user:password@localhost:5432/mydb

# JWT secret for auth = "jwt" routes in gateway.toml
FLUX_JWT_SECRET=change-me-in-production

# API key for auth = "api_key" routes
FLUX_API_KEY=change-me-in-production

# Secrets accessed via ctx.secrets.get("KEY") in functions
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
