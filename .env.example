# Fluxbase self-host environment configuration
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# Postgres 14+ connection string.
# Any managed Postgres works: RDS, Supabase, Neon, Fly Postgres, etc.
DATABASE_URL=postgres://user:password@localhost:5432/fluxbase

# License key from https://fluxbase.co/self-host
# Starter (free): single server, up to 500k executions/month
# Team ($49/mo):  unlimited servers, 10M executions/month
FLUXBASE_LICENSE_KEY=

# Secret shared between internal services.
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# ─── Auth ────────────────────────────────────────────────────────────────────

# Firebase project ID for auth (used by the API service).
# Create a project at https://console.firebase.google.com
FIREBASE_PROJECT_ID=

# ─── Optional ────────────────────────────────────────────────────────────────

# Docker image tag. Defaults to latest.
# Pin to a specific version for production: e.g. FLUXBASE_VERSION=0.2.1
FLUXBASE_VERSION=latest

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Ports (change if you have conflicts)
API_PORT=8080
GATEWAY_PORT=8081
DATA_ENGINE_PORT=8082
RUNTIME_PORT=8083
QUEUE_PORT=8084
DASHBOARD_PORT=3000

# CORS origins allowed by the API (comma-separated)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# Dashboard URLs (set these to your actual public API/gateway URLs)
VITE_API_URL=http://localhost:8080
VITE_GATEWAY_URL=http://localhost:8081

# Queue worker settings
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL_MS=500

# Data engine query limits
MAX_NEST_DEPTH=6
MAX_QUERY_LIMIT=5000
DEFAULT_QUERY_LIMIT=100
